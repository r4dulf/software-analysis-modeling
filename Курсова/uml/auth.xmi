@startuml
start

:Вхід у систему;

if (Є обліковий запис?) then (Так)
  :Введення логіну і пароля;
  :Перевірка даних;

  if (Дані коректні?) then (Так)
    :Надання доступу до системи;
  else (Ні)
    :Повідомлення про помилку;
    :Повторне введення даних;
  endif

else (Ні)
  :Перехід до реєстрації;
  :Введення реєстраційних даних;
  :Перевірка коректності даних;

  if (Дані коректні?) then (Так)
    :Створення облікового запису;
    :Повідомлення про успішну реєстрацію;
    :Надання доступу до системи;
  else (Ні)
    :Повідомлення про помилку;
    :Повторне введення даних;
  endif

endif

stop
@enduml
