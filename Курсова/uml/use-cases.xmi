@startuml
left to right direction

actor "Користувач" as User
actor "Адміністратор" as Admin

rectangle "Програмна платформа автоматизованого\nкерування житловим середовищем" {

  usecase "Авторизація" as UC1
  usecase "Реєстрація" as UC2
  usecase "Перегляд особистих даних" as UC3
  usecase "Зміна особистих даних" as UC4
  usecase "Перегляд пристроїв" as UC5
  usecase "Редагування / видалення\nпристроїв" as UC6
  usecase "Керування пристроями" as UC7
  usecase "Створення сценаріїв\nавтоматизації" as UC8
  usecase "Запуск сценаріїв" as UC9
  usecase "Отримання сповіщень" as UC10
  usecase "Перегляд журналу подій" as UC11
  usecase "Управління користувачами\nплатформи" as UC12
  usecase "Управління пристроями\nта сценаріями" as UC13
  usecase "Перегляд аналітики системи" as UC14
}

User -- UC1
User -- UC2
User -- UC3
User -- UC4
User -- UC5
User -- UC6
User -- UC7
User -- UC8
User -- UC9
User -- UC10
User -- UC11

Admin -- UC1
Admin -- UC2
Admin -- UC3
Admin -- UC4
Admin -- UC5
Admin -- UC6
Admin -- UC12
Admin -- UC13
Admin -- UC14

@enduml
